#!/bin/sh
# Run verify checks for all packages before pushing.
# This ensures lint, type-check, build, and unit tests pass across all packages.

echo "Running verify checks before push..."

npx nx run-many -t verify
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "pre-push: verify checks failed. Push aborted."
  exit 1
fi

echo "pre-push: all checks passed."
