{
  "name": "opcjs-base",
  "version": "0.1.25-alpha",
  "description": "Base functionalities for OPC UA.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iarbre/opcjs.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint ./src",
    "verify": "npx tsc --noEmit",
    "build": "tsup",
    "prepublish": "npm run lint && npm run verify && npm run build && npm run test",
    "dev": "tsup --watch",
    "test": "vitest",
    "generate": "node ../generator/dist/cli.js ../../../ext/UA-NodeSet/Schema/Opc.Ua.NodeSet2.Services.xml -o src/schema"
  },
  "keywords": [
    "opcua",
    "opc-ua"
  ],
  "author": "slompf18",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.1"
  }
}
