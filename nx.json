{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",  "tui": {
    "enabled": false
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "{projectRoot}/src/**/*",
        "{workspaceRoot}/eslint.config.js"
      ],
      "cache": true
    },
    "tsc": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "^production"
      ],
      "cache": true
    },
    "tsc:test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tests/**/*",
        "{projectRoot}/tsconfig.test.json",
        "^production"
      ],
      "cache": true
    },
    "test:unit": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "test:int": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "cache": false
    },
    "verify": {
      "dependsOn": [
        "^verify"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/tests/**/*",
      "!{projectRoot}/**/*.test.ts"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/package.json"
    ]
  },
  "analytics": false
}